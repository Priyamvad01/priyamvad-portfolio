# Public site URL used for metadata and deployment previews.
# Optional on Vercel because the app can fall back to VERCEL_URL.
# Set this when a custom production domain is connected.
NEXT_PUBLIC_SITE_URL=

# Optional contact provider endpoint.
# Example: Formspree endpoint, EmailJS-compatible webhook, or custom backend URL.
# When unset, /api/contact returns an honest "not configured" response.
CONTACT_FORM_ENDPOINT=
